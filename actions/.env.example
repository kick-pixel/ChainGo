# ════════════════════════════════════════════════
# ChainGo Actions API — 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ════════════════════════════════════════════════

# ── Solana 合约 ──────────────────────────────────
# anchor deploy 后获得的 Program ID；未部署前可用 111... 仅用于本地构建
PROGRAM_ID=11111111111111111111111111111111

# ── Solana 网络 ──────────────────────────────────
RPC_URL=https://api.devnet.solana.com

# ── 应用 URL ─────────────────────────────────────
# 本 Actions API 自身的公开 URL（Vercel 部署后填入）
ACTIONS_URL=http://localhost:3000
# TMA 前端的 URL（Blink 完成后跳转目标）
TMA_URL=http://localhost:5173
