# ════════════════════════════════════════════════
# ChainGo TMA Frontend — 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ════════════════════════════════════════════════
# ── Solana 合约 ──────────────────────────────────
# anchor deploy 后获得的 Program ID；未部署前可用 111... 仅用于本地构建
VITE_PROGRAM_ID=11111111111111111111111111111111

# ── Solana 网络 ──────────────────────────────────
# 基础链 RPC（devnet / mainnet-beta）
VITE_BASE_RPC=https://api.devnet.solana.com
# Explorer/network label: devnet, testnet, mainnet-beta, or custom
VITE_SOLANA_CLUSTER=devnet
# MagicBlock Ephemeral Rollup RPC
VITE_ER_RPC=https://devnet-as.magicblock.app

# ── MagicBlock 地址（SDK 默认值；如 Address Book 更新可覆盖）────────
VITE_DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh
VITE_MAGIC_CONTEXT=MagicContext1111111111111111111111111111111
VITE_MAGIC_PROGRAM=Magic11111111111111111111111111111111111111

# ── 应用 URL ─────────────────────────────────────
# Solana Actions API 部署地址（Vercel 部署后填入）
VITE_ACTIONS_BASE_URL=http://localhost:3000
# TMA 本身的 URL（用于 Blink 完成后跳回）
VITE_TMA_URL=http://localhost:5173
